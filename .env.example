# Copiá este archivo como ".env" y completá los valores.

# Ruta al JSON de la cuenta de servicio de Firebase (Admin SDK).
GOOGLE_APPLICATION_CREDENTIALS=./secrets/serviceAccountKey.json

# API key de Gemini (Google AI Studio → https://aistudio.google.com/apikey).
GEMINI_API_KEY=

# Modelo de Gemini a usar.
GEMINI_MODEL=gemini-2.5-flash

# Puerto del backend (el front corre en 3000).
PORT=3001

# Origen permitido por CORS (URL del front).
FRONT_ORIGIN=http://localhost:3000
